{
  "name": "lram",
  "version": "0.1.2-alpha.17",
  "description": "lontten lram markdown js",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    },
    "./lram.scss": "./lram.scss"
  },
  "files": [
    "dist",
    "lram.scss",
    "README.md"
  ],
  "repository": {
    "url": "https://github.com/lontten/lram.git"
  },
  "scripts": {
    "dev": "tsup --watch",
    "build": "tsup",
    "prerelease": "npm run build",
    "release": "bumpp && npm publish"
  },
  "keywords": [
    "lontten",
    "lram",
    "markdown"
  ],
  "author": "lontten",
  "license": "MIT",
  "dependencies": {
    "highlight.js": "^11.11.1",
    "katex": "^0.16.23"
  },
  "devDependencies": {
    "@types/katex": "^0.16.7",
    "@types/node": "^24.7.0",
    "bumpp": "^10.3.1",
    "npm-run-all": "^4.1.5",
    "sass": "^1.93.2",
    "ts-node": "^10.9.2",
    "tsup": "^8.5.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org"
  }
}
