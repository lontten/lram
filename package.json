{
  "name": "lram",
  "version": "0.1.2-alpha.12",
  "description": "lontten lram markdown js",
  "files": [
    "dist/",
    "README.md",
    "lram.css"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "repository": {
    "url": "https://github.com/lontten/lram.git"
  },
  "scripts": {
    "test": "vitest",
    "build:ts": "tsc",
    "build:scss": "npm run generate:scss",
    "dev:scss": "npm run generate:scss",
    "generate:scss": "sass lram.scss:lram.css",
    "clean": "rm -rf dist",
    "release": "npm run clean && run-s build:* && npm publish"
  },
  "keywords": [
    "lontten",
    "lram",
    "markdown"
  ],
  "author": "lontten",
  "license": "MIT",
  "dependencies": {
    "highlight.js": "^11.11.1",
    "katex": "^0.16.23"
  },
  "devDependencies": {
    "@types/katex": "^0.16.7",
    "@types/node": "^24.6.2",
    "vitest": "^3.2.4",
    "ts-node": "^10.9.2",
    "sass": "^1.93.2",
    "npm-run-all": "^4.1.5",
    "tslint": "^6.1.3",
    "typescript": "^5.9.3",
    "@biomejs/biome": "2.2.5"
  },
  "engines": {
    "node": ">=8"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org"
  }
}
